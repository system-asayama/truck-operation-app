{
  "expo": {
    "name": "トラック運行管理",
    "slug": "truck-operation-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3a5c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asayama.truckoperationapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "運行中のGPS位置情報を記録するために使用します。",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "バックグラウンドでもGPS位置情報を記録するために使用します。",
        "NSLocationAlwaysUsageDescription": "バックグラウンドでもGPS位置情報を記録するために使用します。",
        "NSCameraUsageDescription": "顔認証による本人確認のためにカメラを使用します。",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a3a5c"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA"
      ],
      "package": "com.asayama.truckoperationapp",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "バックグラウンドでもGPS位置情報を記録するために使用します。",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "顔認証による本人確認のためにカメラを使用します。"
        }
      ]
    ]
  }
}
